# =============================================================================
# Vireos Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values.
# Variables marked [REQUIRED] will cause a startup failure if missing.
# Variables marked [OPTIONAL] have defaults shown.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# [OPTIONAL] Server runtime environment. Controls log levels, error verbosity.
# Values: development | production | test
NODE_ENV=development

# [OPTIONAL] HTTP port to listen on. Default: 3000
# In Docker, this port handles HTTP->HTTPS redirect.
PORT=13000
HOST_PORT=13000
HOST_HTTPS_PORT=13443
HTTPS_PORT=3443
EXTERNAL_HTTPS_PORT=13443
ENABLE_HTTPS=true
SSL_CERT_PATH=/app/backend/certs/dev-cert.pem
SSL_KEY_PATH=/app/backend/certs/dev-key.pem
FRONTEND_DIST_DIR=/app/backend/public

# [OPTIONAL] Base URL for this API (used in OAuth redirects, emails, etc.)
API_BASE_URL=https://localhost:13443

# [OPTIONAL] Allowed CORS origins (comma-separated list)
# Example: https://app.vireos.com,https://staging.vireos.com
CORS_ORIGINS=http://localhost:13000,https://localhost:13443,https://127.0.0.1:13443,http://localhost:5173,https://<host-ip>:13443

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://vireos:vireos_dev@localhost:55432/vireos?schema=public

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# [REQUIRED] Redis connection URL (used by BullMQ and rate-limit-redis)
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:16379

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------

# [REQUIRED] Secret key for signing JWTs. Use a long, random string (64+ chars).
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_use_openssl_rand_hex_64

# [OPTIONAL] Access token lifetime. Default: 15m
# Examples: 15m, 1h, 24h
JWT_EXPIRES_IN=15m

# [OPTIONAL] Refresh token lifetime. Default: 7d
# Examples: 7d, 30d
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM for OAuth tokens at rest)
# -----------------------------------------------------------------------------

# [REQUIRED] 32-byte (256-bit) hex-encoded key for AES-256-GCM encryption.
# Generate with: openssl rand -hex 32
# IMPORTANT: Changing this key will render all previously encrypted data unreadable.
ENCRYPTION_KEY=change_me_use_openssl_rand_hex_32_characters_total

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------

# [REQUIRED] OpenAI API key for AI content generation features.
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# [OPTIONAL] OpenAI model to use for content generation. Default: gpt-4o
OPENAI_MODEL=gpt-4o

# [OPTIONAL] OpenAI organization ID (if using an organization account)
# OPENAI_ORG_ID=org-...

# -----------------------------------------------------------------------------
# LinkedIn OAuth (Social Publishing)
# -----------------------------------------------------------------------------

# [REQUIRED] LinkedIn application Client ID
# Create an app at: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id

# [REQUIRED] LinkedIn application Client Secret
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# [REQUIRED] LinkedIn OAuth2 callback URL. Must match exactly what's registered in LinkedIn app.
# Example: https://app.vireos.com/api/v1/oauth/linkedin/callback
LINKEDIN_REDIRECT_URI=https://localhost:13443/api/v1/oauth/linkedin/callback

# -----------------------------------------------------------------------------
# Facebook / Meta OAuth (Social Publishing)
# -----------------------------------------------------------------------------

# [REQUIRED] Facebook application App ID
# Create an app at: https://developers.facebook.com/apps
FACEBOOK_APP_ID=1216531970647547

# [REQUIRED] Facebook application App Secret
FACEBOOK_APP_SECRET=b5231c1aab38f7235e2706a2a6ad2c26

# [REQUIRED] Facebook OAuth2 callback URL. Must match exactly what's registered.
# Example: https://app.vireos.com/api/v1/oauth/facebook/callback
FACEBOOK_REDIRECT_URI=https://localhost:13443/api/v1/oauth/facebook/callback

# -----------------------------------------------------------------------------
# SendGrid (Email)
# -----------------------------------------------------------------------------

# [REQUIRED] SendGrid API key for transactional email sending.
# Obtain from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# [OPTIONAL] Default "From" email address for system emails
SENDGRID_FROM_EMAIL=noreply@vireos.com

# [OPTIONAL] Default "From" name for system emails
SENDGRID_FROM_NAME=Vireos Platform

# -----------------------------------------------------------------------------
# Stripe (Payments & Subscriptions)
# -----------------------------------------------------------------------------

# [REQUIRED] Stripe secret key (sk_live_... or sk_test_...)
# Obtain from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# [REQUIRED] Stripe webhook signing secret for validating webhook events.
# Obtain from: https://dashboard.stripe.com/webhooks (after creating the webhook)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# [REQUIRED for billing] Stripe Price IDs for subscription plans.
# Create these in Stripe Dashboard → Products → Prices, then paste the IDs here.
# Without these, clicking "Choose Individual/Team" will fail with INTERNAL_ERROR.
STRIPE_PRICE_INDIVIDUAL=price_your_individual_plan_price_id
STRIPE_PRICE_TEAM=price_your_team_plan_price_id

# [OPTIONAL] Stripe publishable key (used for frontend, surfaced through config endpoint)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# -----------------------------------------------------------------------------
# AWS S3 (File Storage — headshots, PDFs, media uploads)
# -----------------------------------------------------------------------------

# [REQUIRED] AWS IAM access key ID with S3 permissions
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# [REQUIRED] AWS IAM secret access key
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# [REQUIRED] S3 bucket name for file storage
AWS_S3_BUCKET=vireos-uploads-dev

# [REQUIRED] AWS region where the S3 bucket is located
# Example: us-east-1, us-west-2, eu-west-1
AWS_REGION=us-east-1

# [OPTIONAL] Custom S3 endpoint (for LocalStack or MinIO in dev)
# AWS_S3_ENDPOINT=http://localhost:4566

# -----------------------------------------------------------------------------
# Rate Limiting (optional overrides)
# -----------------------------------------------------------------------------

# [OPTIONAL] Global rate limit: requests per window per IP. Default: 100
RATE_LIMIT_GLOBAL_MAX=100

# [OPTIONAL] Global rate limit window in milliseconds. Default: 900000 (15 min)
RATE_LIMIT_GLOBAL_WINDOW_MS=900000

# [OPTIONAL] Auth endpoint rate limit: requests per window per IP. Default: 10
RATE_LIMIT_AUTH_MAX=10

# [OPTIONAL] Auth endpoint rate limit window in milliseconds. Default: 60000 (1 min)
RATE_LIMIT_AUTH_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# [OPTIONAL] Minimum log level to output. Default: info in prod, debug in dev
# Values: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# [OPTIONAL] Service name included in all structured log entries
LOG_SERVICE_NAME=vireos-backend
